# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.local
.env*.local

# uploads (사용자 업로드 이미지)
/uploads/input/*
/uploads/output/*
/uploads/color/*
!uploads/input/.gitkeep
!uploads/output/.gitkeep
!uploads/color/.gitkeep

# temp files
check-models.js

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
